# Copy this to .env and fill in your values
# The app reads these automatically at startup

# Required for VLM reasoning (GPT-4V) — optional feature
OPENAI_API_KEY=sk-...

# Model directory (absolute path on the EC2 instance)
MODEL_DIR=/home/ubuntu/age-verify-app/models

# Default CNN backbone
MODEL_BACKBONE=densenet

# Flask secret key — change this!
SECRET_KEY=change-me-in-production-use-a-random-string

# Port (Gunicorn/Flask listen port — Nginx proxies to this)
PORT=5000
